# Stage 1: Build the Codyx binary
FROM rust:1-bookworm AS builder

RUN apt-get update && apt-get install -y \
    pkg-config cmake \
    libwebkit2gtk-4.1-dev libgtk-3-dev libglib2.0-dev \
    libxdo-dev libayatana-appindicator3-dev \
    libssl-dev libsqlite3-dev \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /build
COPY Cargo.toml Cargo.lock ./
COPY crates/ crates/
RUN cargo build --package codex-app --bin codyx --release \
    && strip /build/target/release/codyx \
    && rm -rf /build/target/release/.fingerprint /build/target/release/deps /build/target/release/build /build/target/release/incremental

# Stage 2: Test runner with Playwright
FROM mcr.microsoft.com/playwright/python:v1.49.0-noble

# Runtime deps for the Codyx binary
RUN apt-get update && apt-get install -y \
    libwebkit2gtk-4.1-0 libgtk-3-0 libglib2.0-0 \
    xvfb dbus-x11 \
    && rm -rf /var/lib/apt/lists/*

COPY --from=builder /build/target/release/codyx /usr/local/bin/codyx

WORKDIR /tests
COPY tests/e2e/requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY tests/e2e/ .

ENV CODYX_BINARY=/usr/local/bin/codyx
# Virtual display for headless WebKit
ENV DISPLAY=:99

# Start Xvfb + run tests
ENTRYPOINT ["bash", "-c", "Xvfb :99 -screen 0 1280x720x24 &>/dev/null & sleep 1 && dbus-daemon --session --fork && python -m pytest -v \"$@\"", "--"]
