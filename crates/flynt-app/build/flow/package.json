{
  "name": "flynt-flow-bundle",
  "version": "0.1.0",
  "private": true,
  "description": "React + react-flow bundle that powers the .flow editor inside Flynt's webview. Built once via `npm run build`; the result lives at crates/flynt-app/assets/vendor/flow.bundle.js and is committed alongside other vendored bundles.",
  "scripts": {
    "build": "esbuild src/index.tsx --bundle --minify --format=iife --target=es2020 --outfile=../../assets/vendor/flow.bundle.js --define:process.env.NODE_ENV=\\\"production\\\" --loader:.css=text",
    "build:dev": "esbuild src/index.tsx --bundle --format=iife --target=es2020 --sourcemap --outfile=../../assets/vendor/flow.bundle.js --define:process.env.NODE_ENV=\\\"development\\\" --loader:.css=text"
  },
  "dependencies": {
    "@xyflow/react": "^12.3.5",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@types/react": "^18.3.12",
    "@types/react-dom": "^18.3.1",
    "esbuild": "^0.24.0"
  }
}
